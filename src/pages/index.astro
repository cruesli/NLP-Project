---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/withBase";
---

<BaseLayout title="Family Recipes">
  <h1>Family Recipes</h1>

  <h2>Create new recipe</h2>
  <p>
    When we add the CMS, this will link to the editor.
    For now, you create a new recipe by adding a Markdown file under
    <code>src/content/recipes/</code>.
  </p>
  <p><a class="card" href={withBase("/admin")}>Go to Admin (later)</a></p>
</BaseLayout>
