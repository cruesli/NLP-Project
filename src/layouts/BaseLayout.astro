---
import { withBase } from "../utils/withBase";
const { title = "Family Recipes" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script>
        (function () {
          // Only do this on the Netlify admin site, not on GitHub Pages.
          if (location.hostname !== "mtrecipes.netlify.app") return;
      
          const h = location.hash || "";
          const isInvite =
            h.includes("invite_token=") ||
            h.includes("recovery_token=") ||
            h.includes("confirmation_token=") ||
            h.includes("access_token=");
      
          if (isInvite) {
            location.replace("/admin/" + h);
          }
        })();
      </script>
    <link rel="stylesheet" href={withBase("/styles/global.css")} />
  </head>
  <body>
    <header class="container header">
      <a class="brand" href={withBase("/")}>Magnus og Tesserns oppskrifter</a>
      <nav class="nav">
        <a href={withBase("/")}>Cuisines</a>
        <a href={withBase("/meal-planner")}>Meal Planner</a>
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="container footer">
      <small>© {new Date().getFullYear()} Magnus og Tesserns oppskrifter</small>
    </footer>
  </body>
</html>
