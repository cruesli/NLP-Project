---
import { withBase } from "../utils/withBase";
import { getCollection } from "astro:content";

const { title = "Family Recipes" } = Astro.props;

const recipes = await getCollection("recipes");
const cuisineSet = new Set(
  recipes.map((r) => (r.data.cuisine || "other").toLowerCase())
);
const cuisines = Array.from(cuisineSet).sort((a, b) => a.localeCompare(b));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script>
        (function () {
          // Only do this on the Netlify admin site, not on GitHub Pages.
          if (location.hostname !== "mtrecipes.netlify.app") return;
      
          const h = location.hash || "";
          const isInvite =
            h.includes("invite_token=") ||
            h.includes("recovery_token=") ||
            h.includes("confirmation_token=") ||
            h.includes("access_token=");
      
          if (isInvite) {
            location.replace("/admin/" + h);
          }
        })();
      </script>
    <link rel="stylesheet" href={withBase("/styles/global.css")} />
  </head>
  <body>
    <header class="container header">
      <a class="brand" href={withBase("/")}>Magnus og Tesserns oppskrifter</a>
      <nav class="nav">
        <a href={withBase("/")}>Cuisines</a>
        <a href={withBase("/meal-planner")}>Meal Planner</a>
      </nav>
    </header>

    <main class="container">
      <div class="layout-sidebar">
        <aside class="sidebar">
          <h2>Cuisines</h2>
          <nav class="sidebar-cuisines">
            {cuisines.map((cuisine) => (
              <a class="sidebar-cuisine-link" href={withBase(`/cuisines/${cuisine}`)}>
                {cuisine}
              </a>
            ))}
          </nav>
        </aside>
        <section class="content-main">
          <slot />
        </section>
      </div>
    </main>

    <footer class="container footer">
      <small>© {new Date().getFullYear()} Magnus og Tesserns oppskrifter</small>
    </footer>
  </body>
</html>
